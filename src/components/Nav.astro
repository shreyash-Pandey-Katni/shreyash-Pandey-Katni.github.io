---
import { navigationLinks, primaryContactHref } from '../data/siteContent';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="nav" role="navigation" aria-label="Main">
  <div class="nav__inner">
    {/* Logo */}
    <a href="/" class="nav__logo" aria-label="Home">
      <img src="/icon.svg" alt="Shreyash Pandey" class="nav__avatar" />
    </a>

    {/* Desktop links */}
    <div class="nav__links">
      {navigationLinks.map((link) => {
        const isActive = currentPath === link.path || (link.path === '/' && currentPath === '/');
        return (
          <a
            href={link.path}
            class={`nav__link${isActive ? ' nav__link--active' : ''}`}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <div class="nav__actions nav__actions--desktop">
      {/* Theme toggle */}
      <button class="theme-toggle" type="button" aria-label="Toggle theme">
        {/* Moon: shown in light mode */}
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        {/* Sun: shown in dark mode */}
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      {/* Desktop Resume */}
      <a
        href="/Shreyash_Pandey_Resume.pdf"
        download
        class="btn btn--secondary btn--sm"
      >
        Resume ↓
      </a>

      {/* Desktop CTA */}
      <a href={primaryContactHref} class="nav__cta">
        Get in touch
      </a>
    </div>

    {/* Mobile: theme toggle + hamburger */}
    <div class="nav__mobile-actions">
      <button class="theme-toggle" type="button" aria-label="Toggle theme">
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
      <button
        class="nav__toggle"
        onclick="this.classList.toggle('nav__toggle--open'); document.querySelector('.nav__overlay').classList.toggle('nav__overlay--open'); document.body.style.overflow = document.body.style.overflow ? '' : 'hidden';"
        aria-expanded="false"
        aria-label="Open menu"
      >
        <span class="nav__toggle-bar"></span>
      </button>
    </div>
  </div>
</nav>

{/* Mobile overlay */}
<div class="nav__overlay" aria-hidden="true">
  {navigationLinks.map((link) => {
    const isActive = currentPath === link.path || (link.path === '/' && currentPath === '/');
    return (
      <a
        href={link.path}
        class={`nav__overlay-link${isActive ? ' nav__overlay-link--active' : ''}`}
        onclick="document.querySelector('.nav__toggle').classList.remove('nav__toggle--open'); document.querySelector('.nav__overlay').classList.remove('nav__overlay--open'); document.body.style.overflow = '';"
      >
        {link.label}
      </a>
    );
  })}
  <div class="nav__overlay-cta">
    <a
      href="/Shreyash_Pandey_Resume.pdf"
      download
      class="btn btn--secondary"
      style="width: 100%; justify-content: center;"
    >
      Resume ↓
    </a>
    <a
      href={primaryContactHref}
      class="btn btn--primary"
      style="width: 100%; justify-content: center;"
    >
      Get in touch
    </a>
  </div>
</div>

<script is:inline>
  /* Smooth scroll to top on nav click */
  document.querySelectorAll('.nav__overlay-link').forEach(link => {
    link.addEventListener('click', () => {
      setTimeout(() => window.scrollTo(0, 0), 0);
    });
  });
</script>

<style is:global>
  /* Styles are in index.css */
</style>
