---
// Semantic Search — real neural embeddings (bge-small-en-v1.5) running in the
// visitor's browser via Transformers.js. Docs are embedded once on load, the
// query on each input, ranked by cosine similarity. If the model can't load,
// it falls back to in-browser TF-IDF and labels itself accordingly.
import { projects } from "../../data/demoContent.js";
const corpus = projects.map((p) => ({
  id: p.id,
  title: p.title,
  category: p.category,
  text: `${p.title}. ${p.category}. ${p.summary} ${p.tech.join(" ")}`,
}));
---

<div class="demo-search" data-corpus={JSON.stringify(corpus)}>
  <div class="ss-bar">
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M21 21l-4.3-4.3M11 18a7 7 0 100-14 7 7 0 000 14z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    <input class="ss-input" placeholder="describe what you are looking for..." spellcheck="false" />
    <span class="ss-engine" data-state="idle">·</span>
  </div>
  <div class="ss-chips">
    <button data-q="training a language model from scratch">training an LLM</button>
    <button data-q="coordinating multiple AI agents with a critic">multi-agent systems</button>
    <button data-q="keep automated tests working when the UI changes">reliable tests</button>
    <button data-q="finding local businesses and reaching out to them">local outreach</button>
  </div>
  <div class="ss-results" aria-live="polite"></div>
</div>

<style is:global>
  .demo-search { font-family: var(--demo-sans, "Inter", system-ui, sans-serif); color: var(--demo-fg, #18181b); }
  .ss-bar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; padding: 12px 16px; border-radius: 12px;
    border: 1px solid var(--demo-border, #e4e4e7); background: var(--demo-surface, #fff); color: var(--demo-muted, #71717a); }
  .ss-bar:focus-within { border-color: var(--demo-accent, #6d28d9); }
  .ss-input { flex: 1 1 120px; min-width: 0; border: 0; outline: 0; background: transparent; font: inherit; font-size: 15px; color: var(--demo-fg, #18181b); }
  .ss-engine { font-family: var(--demo-mono, monospace); font-size: 10px; padding: 3px 8px; border-radius: 999px;
    border: 1px solid var(--demo-border, #e4e4e7); white-space: nowrap; }
  .ss-engine[data-state="neural"] { color: #16a34a; border-color: color-mix(in srgb, #16a34a 40%, transparent); }
  .ss-engine[data-state="neural"]::before { content: "● "; }
  .ss-engine[data-state="loading"] { color: var(--demo-accent, #6d28d9); border-color: color-mix(in srgb, var(--demo-accent, #6d28d9) 40%, transparent); }
  .ss-engine[data-state="lexical"] { color: #d97706; border-color: color-mix(in srgb, #d97706 40%, transparent); }
  .ss-chips { display: flex; gap: 8px; flex-wrap: wrap; margin: 12px 0; }
  .ss-chips button { font: inherit; font-size: 12px; cursor: pointer; padding: 5px 12px; border-radius: 999px;
    border: 1px solid var(--demo-border, #e4e4e7); background: transparent; color: var(--demo-fg, #18181b); }
  .ss-chips button:hover { border-color: var(--demo-accent, #6d28d9); color: var(--demo-accent, #6d28d9); }
  .ss-results { display: grid; gap: 8px; }
  .ss-hit { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 12px;
    padding: 12px 15px; border-radius: 11px; border: 1px solid var(--demo-border, #e4e4e7);
    background: var(--demo-surface, #fff); animation: ss-in .25s ease both; }
  @keyframes ss-in { from { opacity: 0; transform: translateY(4px); } }
  .ss-hit h5 { margin: 0 0 2px; font-size: 14px; }
  .ss-hit small { font-size: 11px; color: var(--demo-muted, #71717a); font-family: var(--demo-mono, monospace); }
  .ss-score { text-align: right; min-width: 96px; }
  .ss-score b { font-family: var(--demo-mono, monospace); font-size: 12px; color: var(--demo-accent, #6d28d9); }
  .ss-meter { height: 4px; border-radius: 2px; margin-top: 4px; background: var(--demo-surface-2, #f1f1f3); overflow: hidden; }
  .ss-meter i { display: block; height: 100%; background: var(--demo-accent, #6d28d9); border-radius: 2px; transition: width .3s; }
  .ss-empty { font-size: 13px; color: var(--demo-muted, #71717a); padding: 8px 2px; }
</style>

<script>
  const MODEL = "Xenova/bge-small-en-v1.5";
  const QUERY_PREFIX = "Represent this sentence for searching relevant passages: ";

  let libPromise = null;
  function loadLib() {
    if (!libPromise) libPromise = import("https://esm.sh/@huggingface/transformers@3")
      .then((mod) => { mod.env.allowLocalModels = false; return mod; });
    return libPromise;
  }

  const STOP = new Set("a an the of and to in is it for on with from at as by this that or be are was".split(" "));
  const tok = (s) => (s.toLowerCase().match(/[a-z0-9]+/g) || []).filter((w) => w.length > 1 && !STOP.has(w));
  const dot = (a, b) => { let s = 0; for (let i = 0; i < a.length; i++) s += a[i] * b[i]; return s; };

  document.querySelectorAll(".demo-search").forEach((root) => {
    const docs = JSON.parse(root.dataset.corpus);
    const input = root.querySelector(".ss-input");
    const out = root.querySelector(".ss-results");
    const engineEl = root.querySelector(".ss-engine");
    const setEngine = (state, label) => { engineEl.dataset.state = state; engineEl.textContent = label; };

    /* ---- lexical fallback (TF-IDF + cosine) ---- */
    const N = docs.length, df = {};
    docs.forEach((d) => {
      d.tf = {}; const ws = tok(d.text);
      ws.forEach((w) => (d.tf[w] = (d.tf[w] || 0) + 1));
      new Set(ws).forEach((w) => (df[w] = (df[w] || 0) + 1));
    });
    const idf = (w) => Math.log((N + 1) / ((df[w] || 0) + 1)) + 1;
    const tfidf = (tf) => { const v = {}; let n = 0; for (const w in tf) { const x = tf[w] * idf(w); v[w] = x; n += x * x; } n = Math.sqrt(n) || 1; for (const w in v) v[w] /= n; return v; };
    docs.forEach((d) => (d.lex = tfidf(d.tf)));
    function lexicalRank(q) {
      const qtf = {}; tok(q).forEach((w) => (qtf[w] = (qtf[w] || 0) + 1));
      const qv = tfidf(qtf);
      return docs.map((d) => { let s = 0; for (const w in qv) if (d.lex[w]) s += qv[w] * d.lex[w]; return { d, score: s }; })
        .sort((a, b) => b.score - a.score).filter((r) => r.score > 0.001);
    }

    /* ---- neural path (bge-small embeddings) ---- */
    let extractor = null, ready = false;
    async function embed(text) { const o = await extractor(text, { pooling: "mean", normalize: true }); return Array.from(o.data); }
    async function initNeural() {
      try {
        setEngine("loading", "loading model…");
        const lib = await loadLib();
        extractor = await lib.pipeline("feature-extraction", MODEL);
        for (const d of docs) d.vec = await embed(d.text);
        ready = true;
        setEngine("neural", "neural · bge-small");
        if (input.value.trim()) search(input.value);
      } catch (e) {
        ready = false;
        setEngine("lexical", "lexical (TF-IDF)");
      }
    }
    async function neuralRank(q) {
      const qv = await embed(QUERY_PREFIX + q);
      return docs.map((d) => ({ d, score: (dot(qv, d.vec) + 1) / 2 }))
        .sort((a, b) => b.score - a.score);
    }

    function paint(ranked) {
      if (!ranked.length) { out.innerHTML = '<p class="ss-empty">No match in the corpus.</p>'; return; }
      const top = ranked[0].score || 1;
      out.innerHTML = ranked.slice(0, 4).map(({ d, score }) => `
        <div class="ss-hit">
          <div><h5>${d.title}</h5><small>${d.category}</small></div>
          <div class="ss-score"><b>${score.toFixed(3)}</b>
            <div class="ss-meter"><i style="width:${Math.round((score / top) * 100)}%"></i></div></div>
        </div>`).join("");
    }

    let seq = 0;
    async function search(q) {
      if (!q.trim()) { out.innerHTML = '<p class="ss-empty">Start typing, or pick a suggestion above.</p>'; return; }
      const mine = ++seq;
      if (ready) {
        const ranked = await neuralRank(q);
        if (mine === seq) paint(ranked);
      } else {
        paint(lexicalRank(q));
      }
    }

    setEngine("lexical", "lexical (TF-IDF)");
    let t;
    input.addEventListener("input", () => { clearTimeout(t); t = setTimeout(() => search(input.value), 180); });
    root.querySelectorAll(".ss-chips button").forEach((b) =>
      b.addEventListener("click", () => { input.value = b.dataset.q; search(input.value); input.focus(); }));
    search("");
    initNeural(); // upgrade to neural in the background
  });
</script>
