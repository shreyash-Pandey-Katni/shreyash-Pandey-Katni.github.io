---
import { projects, graphHubs, graphEdges, profile, metrics } from "../../data/demoContent.js";
import Tokenizer from "../../components/demos/Tokenizer.astro";
import BeatPhoenix from "../../components/demos/BeatPhoenix.astro";
import AutoHeal from "../../components/demos/AutoHeal.astro";
import SemanticSearch from "../../components/demos/SemanticSearch.astro";

const graphData = {
  projects: projects.map((p) => ({ id: p.id, title: p.title, category: p.category, status: p.status,
    summary: p.summary, stats: p.stats, tech: p.tech, href: p.href })),
  hubs: graphHubs,
  edges: graphEdges,
};
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>01 · Knowledge Graph — Design Demo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #08080f; --panel: rgba(255,255,255,.04); --line: rgba(255,255,255,.09);
      --fg: #ececf2; --muted: #8b8b9a; --violet: #7c5cff; --cyan: #22d3ee; --amber: #fbbf24;
    }
    * { box-sizing: border-box; }
    body { margin: 0; background: var(--bg); color: var(--fg); font-family: "Inter", system-ui, sans-serif; overflow-x: hidden; }
    a { color: var(--violet); }
    @media (max-width: 600px) {
      .section { padding: 48px 16px; }
      .section .metrics { grid-template-columns: repeat(2, 1fr); }
      .hero__intro { left: 18px; right: 18px; max-width: none; }
      .nodepanel { width: 88vw; }
    }

    /* shared demo switcher */
    .demobar { position: sticky; top: 0; z-index: 50; display: flex; align-items: center; gap: 14px;
      padding: 10px 18px; background: rgba(8,8,15,.8); backdrop-filter: blur(10px); border-bottom: 1px solid var(--line);
      font-family: "JetBrains Mono", monospace; font-size: 12px; }
    .demobar a { color: var(--muted); text-decoration: none; }
    .demobar a.active { color: var(--fg); }
    .demobar .spacer { flex: 1; }
    .demobar .pill { padding: 3px 9px; border: 1px solid var(--line); border-radius: 999px; }

    .hero { position: relative; height: min(82vh, 760px); overflow: hidden;
      background: radial-gradient(70% 60% at 50% 35%, rgba(124,92,255,.16), transparent 70%); }
    #graph { position: absolute; inset: 0; width: 100%; height: 100%; display: block; cursor: grab; }
    #graph:active { cursor: grabbing; }
    .hero__intro { position: absolute; top: 34px; left: 34px; max-width: 380px; pointer-events: none; z-index: 2; }
    .hero__intro .eyebrow { font-family: "JetBrains Mono", monospace; font-size: 12px; color: var(--violet);
      letter-spacing: .1em; text-transform: uppercase; margin: 0 0 12px; }
    .hero__intro h1 { font-size: clamp(28px, 4.5vw, 46px); line-height: 1.04; margin: 0 0 14px; font-weight: 800; letter-spacing: -.02em; }
    .hero__intro p { font-size: 15px; line-height: 1.6; color: var(--muted); margin: 0; }
    .hero__hint { position: absolute; bottom: 22px; left: 34px; font-family: "JetBrains Mono", monospace;
      font-size: 11px; color: var(--muted); z-index: 2; pointer-events: none; }

    /* node detail panel */
    .nodepanel { position: absolute; top: 0; right: 0; bottom: 0; width: 340px; max-width: 86vw; z-index: 5;
      background: rgba(12,12,20,.92); backdrop-filter: blur(14px); border-left: 1px solid var(--line);
      padding: 28px 24px; transform: translateX(100%); transition: transform .35s cubic-bezier(.4,0,.2,1); overflow-y: auto; }
    .nodepanel.open { transform: none; }
    .nodepanel__close { position: absolute; top: 16px; right: 18px; background: 0; border: 0; color: var(--muted);
      font-size: 22px; cursor: pointer; line-height: 1; }
    .nodepanel .cat { font-family: "JetBrains Mono", monospace; font-size: 11px; color: var(--cyan);
      text-transform: uppercase; letter-spacing: .08em; }
    .nodepanel h3 { font-size: 24px; margin: 8px 0 4px; }
    .nodepanel .status { font-family: "JetBrains Mono", monospace; font-size: 11px; color: var(--amber); }
    .nodepanel p.sum { font-size: 14px; line-height: 1.6; color: #c8c8d4; margin: 16px 0; }
    .nodepanel .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
    .nodepanel .stat { padding: 9px 11px; border: 1px solid var(--line); border-radius: 9px; }
    .nodepanel .stat b { display: block; font-size: 16px; }
    .nodepanel .stat span { font-size: 11px; color: var(--muted); }
    .nodepanel .tech { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 18px; }
    .nodepanel .tech span { font-size: 11px; padding: 3px 9px; border-radius: 999px; border: 1px solid var(--line); color: var(--muted); }
    .nodepanel .open-link { display: inline-block; font-size: 13px; font-weight: 600; padding: 9px 16px;
      border-radius: 9px; background: var(--violet); color: #fff; text-decoration: none; }

    .section { max-width: 1080px; margin: 0 auto; padding: 64px 24px; }
    .section > .eyebrow { font-family: "JetBrains Mono", monospace; font-size: 12px; color: var(--violet);
      letter-spacing: .1em; text-transform: uppercase; margin: 0 0 8px; }
    .section > h2 { font-size: 30px; margin: 0 0 8px; letter-spacing: -.01em; }
    .section > .sub { color: var(--muted); margin: 0 0 28px; max-width: 620px; line-height: 1.6; }

    .metrics { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 8px; }
    @media (max-width: 820px) { .metrics { grid-template-columns: repeat(3, 1fr); } }
    .metric { border: 1px solid var(--line); border-radius: 12px; padding: 16px 14px; background: var(--panel); }
    .metric b { display: block; font-size: 24px; font-weight: 800; }
    .metric span { font-size: 11px; color: var(--muted); line-height: 1.3; display: block; margin-top: 4px; }

    .demo-card { border: 1px solid var(--line); border-radius: 18px; background: var(--panel); padding: 26px; margin-bottom: 22px;
      --demo-fg: #ececf2; --demo-muted: #8b8b9a; --demo-accent: #7c5cff; --demo-border: rgba(255,255,255,.12);
      --demo-surface: rgba(255,255,255,.03); --demo-surface-2: rgba(255,255,255,.05);
      --demo-mono: "JetBrains Mono", monospace; --demo-sans: "Inter", sans-serif; }
    .demo-card h3 { margin: 0 0 4px; font-size: 18px; }
    .demo-card .tagline { font-family: "JetBrains Mono", monospace; font-size: 11px; color: var(--cyan); margin: 0 0 18px; }
    .footer { text-align: center; padding: 40px 20px 64px; color: var(--muted); font-size: 13px; }
  </style>
</head>
<body>
  <nav class="demobar">
    <a href="/demos">← all designs</a>
    <span class="spacer"></span>
    <span class="pill" style="color:var(--fg)">01 Knowledge Graph</span>
    <a href="/demos/terminal">02</a><a href="/demos/paper">03</a><a href="/demos/dashboard">04</a>
  </nav>

  <header class="hero">
    <div class="hero__intro">
      <p class="eyebrow">{profile.role}</p>
      <h1>{profile.name}</h1>
      <p>My work is a graph. Drag the nodes, click a project to open it, click a skill to light up everything connected.</p>
    </div>
    <canvas id="graph"></canvas>
    <p class="hero__hint">drag to rearrange · click a node · scroll for the rest</p>
    <aside class="nodepanel" id="nodepanel">
      <button class="nodepanel__close" aria-label="Close">×</button>
      <div id="panelbody"></div>
    </aside>
  </header>

  <section class="section">
    <p class="eyebrow">Proof</p>
    <h2>What the graph is built on</h2>
    <div class="metrics">
      {metrics.map((m) => (<div class="metric"><b>{m.value}</b><span>{m.label}</span></div>))}
    </div>
  </section>

  <section class="section">
    <p class="eyebrow">Interactive</p>
    <h2>Play with the work, do not just read it</h2>
    <p class="sub">Every demo runs fully in your browser. No backend, no API calls. The same four would anchor the real site.</p>

    <div class="demo-card">
      <h3>Tokenizer Playground</h3>
      <p class="tagline">Phoenix 125M · Sweta multilingual</p>
      <Tokenizer />
    </div>
    <div class="demo-card">
      <h3>Semantic Search</h3>
      <p class="tagline">TF-IDF + cosine over my projects, in-browser</p>
      <SemanticSearch />
    </div>
    <div class="demo-card">
      <h3>Auto-Healing Locators</h3>
      <p class="tagline">IBM SAT · three-tier recovery</p>
      <AutoHeal />
    </div>
    <div class="demo-card">
      <h3>Beat Phoenix 125M</h3>
      <p class="tagline">WinoGrande-style commonsense</p>
      <BeatPhoenix />
    </div>
  </section>

  <p class="footer">Design demo 01 of 4 · <a href="/demos">back to gallery</a></p>

  <script type="application/json" id="graph-data" set:html={JSON.stringify(graphData)}></script>
  <script>
    const DATA = JSON.parse(document.getElementById("graph-data").textContent);
    const canvas = document.getElementById("graph");
    const ctx = canvas.getContext("2d");
    const panel = document.getElementById("nodepanel");
    const panelBody = document.getElementById("panelbody");
    panel.querySelector(".nodepanel__close").addEventListener("click", () => { panel.classList.remove("open"); selected = null; });

    const COL = { project: "#7c5cff", org: "#22d3ee", skill: "#fbbf24" };
    let W = 0, H = 0, DPR = 1;

    // build nodes
    const nodes = [];
    const byId = {};
    DATA.projects.forEach((p) => { const n = { ...p, kind: "project", r: 26 }; nodes.push(n); byId[p.id] = n; });
    DATA.hubs.forEach((h) => { const n = { ...h, kind: h.kind, r: 16 }; nodes.push(n); byId[h.id] = n; });
    const edges = DATA.edges.map(([a, b]) => ({ a: byId[a], b: byId[b] })).filter((e) => e.a && e.b);
    const adj = {};
    edges.forEach((e) => { (adj[e.a.id] ||= new Set()).add(e.b.id); (adj[e.b.id] ||= new Set()).add(e.a.id); });

    function resize() {
      const rect = canvas.getBoundingClientRect();
      DPR = Math.min(window.devicePixelRatio || 1, 2);
      W = rect.width; H = rect.height;
      canvas.width = W * DPR; canvas.height = H * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    }
    resize();
    window.addEventListener("resize", resize);

    // seed positions around center
    nodes.forEach((n, i) => {
      const a = (i / nodes.length) * Math.PI * 2;
      n.x = W / 2 + Math.cos(a) * 160 + (Math.random() - .5) * 40;
      n.y = H / 2 + Math.sin(a) * 140 + (Math.random() - .5) * 40;
      n.vx = 0; n.vy = 0;
    });

    let selected = null, hovered = null, dragging = null, mouse = { x: 0, y: 0 };

    function step() {
      const cx = W / 2, cy = H / 2;
      // repulsion
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          let dx = a.x - b.x, dy = a.y - b.y;
          let d2 = dx * dx + dy * dy || 0.01;
          const f = 2600 / d2;
          const d = Math.sqrt(d2);
          const ux = dx / d, uy = dy / d;
          a.vx += ux * f; a.vy += uy * f; b.vx -= ux * f; b.vy -= uy * f;
        }
      }
      // springs
      edges.forEach((e) => {
        let dx = e.b.x - e.a.x, dy = e.b.y - e.a.y;
        const d = Math.sqrt(dx * dx + dy * dy) || 0.01;
        const rest = 118;
        const f = (d - rest) * 0.012;
        const ux = dx / d, uy = dy / d;
        e.a.vx += ux * f; e.a.vy += uy * f; e.b.vx -= ux * f; e.b.vy -= uy * f;
      });
      // gravity + integrate
      nodes.forEach((n) => {
        n.vx += (cx - n.x) * 0.004; n.vy += (cy - n.y) * 0.004;
        if (n === dragging) { n.x = mouse.x; n.y = mouse.y; n.vx = n.vy = 0; return; }
        n.vx *= 0.86; n.vy *= 0.86;
        n.x += n.vx; n.y += n.vy;
        n.x = Math.max(n.r, Math.min(W - n.r, n.x));
        n.y = Math.max(n.r + 8, Math.min(H - n.r, n.y));
      });
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      const activeId = selected?.id || hovered?.id;
      const lit = activeId ? new Set([activeId, ...(adj[activeId] || [])]) : null;

      edges.forEach((e) => {
        const on = lit && (lit.has(e.a.id) && lit.has(e.b.id));
        ctx.beginPath();
        ctx.moveTo(e.a.x, e.a.y); ctx.lineTo(e.b.x, e.b.y);
        ctx.strokeStyle = on ? "rgba(124,92,255,.55)" : (lit ? "rgba(255,255,255,.05)" : "rgba(255,255,255,.12)");
        ctx.lineWidth = on ? 1.6 : 1;
        ctx.stroke();
      });

      nodes.forEach((n) => {
        const dim = lit && !lit.has(n.id);
        const col = COL[n.kind] || COL.project;
        ctx.globalAlpha = dim ? 0.25 : 1;
        // glow
        if (!dim) {
          ctx.beginPath(); ctx.arc(n.x, n.y, n.r + 6, 0, Math.PI * 2);
          ctx.fillStyle = col + "22"; ctx.fill();
        }
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = n.kind === "project" ? col : "#0b0b14";
        ctx.fill();
        ctx.lineWidth = 2; ctx.strokeStyle = col; ctx.stroke();
        // label
        ctx.globalAlpha = dim ? 0.3 : 1;
        ctx.fillStyle = "#ececf2";
        ctx.font = (n.kind === "project" ? "600 " : "500 ") + (n.kind === "project" ? 12 : 11) + "px Inter, sans-serif";
        ctx.textAlign = "center"; ctx.textBaseline = "middle";
        const label = n.kind === "project" ? n.title.split(" ")[0] : n.label;
        ctx.fillText(label, n.x, n.y + n.r + 12);
      });
      ctx.globalAlpha = 1;
    }

    function loop() { step(); draw(); requestAnimationFrame(loop); }
    loop();

    function pick(x, y) {
      let best = null, bd = 1e9;
      nodes.forEach((n) => { const d = Math.hypot(n.x - x, n.y - y); if (d < n.r + 6 && d < bd) { bd = d; best = n; } });
      return best;
    }
    function rel(e) {
      const r = canvas.getBoundingClientRect();
      const p = e.touches ? e.touches[0] : e;
      return { x: p.clientX - r.left, y: p.clientY - r.top };
    }

    canvas.addEventListener("mousemove", (e) => {
      mouse = rel(e);
      hovered = dragging || pick(mouse.x, mouse.y);
      canvas.style.cursor = hovered ? "pointer" : "grab";
    });
    canvas.addEventListener("mousedown", (e) => { mouse = rel(e); dragging = pick(mouse.x, mouse.y); });
    window.addEventListener("mouseup", () => { dragging = null; });
    canvas.addEventListener("click", (e) => {
      const p = rel(e);
      const hit = pick(p.x, p.y);
      if (hit) selectNode(hit); else { panel.classList.remove("open"); selected = null; }
    });

    function selectNode(n) {
      selected = n;
      if (n.kind === "project") {
        panelBody.innerHTML = `
          <p class="cat">${n.category}</p>
          <h3>${n.title}</h3>
          <p class="status">● ${n.status}</p>
          <p class="sum">${n.summary}</p>
          <div class="stats">${n.stats.map(([k, v]) => `<div class="stat"><b>${v}</b><span>${k}</span></div>`).join("")}</div>
          <div class="tech">${n.tech.map((t) => `<span>${t}</span>`).join("")}</div>
          <a class="open-link" href="${n.href}" target="_blank" rel="noopener">Open project →</a>`;
        panel.classList.add("open");
      } else {
        const linked = [...(adj[n.id] || [])].map((id) => byId[id]).filter((x) => x.kind === "project");
        panelBody.innerHTML = `
          <p class="cat">${n.kind}</p>
          <h3>${n.label}</h3>
          <p class="sum">Projects connected to this ${n.kind}:</p>
          <div class="tech">${linked.map((x) => `<span>${x.title}</span>`).join("")}</div>`;
        panel.classList.add("open");
      }
    }
  </script>
</body>
</html>
