---
// Design exploration gallery. Standalone, does not touch the live site.
const designs = [
  { slug: "graph", name: "Knowledge Graph", tag: "01",
    blurb: "The homepage IS a force-directed graph of projects, skills, and orgs. Click a node to zoom in.",
    vibe: "Most 'you'. Ties to graphify + semantic work.", swatch: ["#0b0b14", "#7c5cff", "#22d3ee"] },
  { slug: "terminal", name: "Terminal / TUI", tag: "02",
    blurb: "Boot sequence, then a real command line. Type projects, cat phoenix, tokenize, theme.",
    vibe: "Systems-engineer identity, hacker credibility.", swatch: ["#0a0e0a", "#33ff99", "#ffcc66"] },
  { slug: "paper", name: "arXiv / Model Card", tag: "03",
    blurb: "Styled as a research paper: abstract, benchmark tables, figures, citations.",
    vibe: "Maximum research credibility for AI roles.", swatch: ["#ffffff", "#111827", "#1d4ed8"] },
  { slug: "dashboard", name: "Mission Control", tag: "04",
    blurb: "A dark observability dashboard: gauges, sparklines, status LEDs, live event log.",
    vibe: "Leans reliability / SRE. The 99.99% story.", swatch: ["#0c1118", "#39d98a", "#ff5c5c"] },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Design Explorations · Shreyash Pandey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; min-height: 100vh; background: #08080c; color: #e7e7ea;
      font-family: "Inter", system-ui, sans-serif;
      background-image: radial-gradient(60% 50% at 50% 0%, rgba(124,92,255,.18), transparent); }
    .wrap { max-width: 1100px; margin: 0 auto; padding: 64px 24px 80px; }
    .eyebrow { font-family: "JetBrains Mono", monospace; font-size: 12px; letter-spacing: .12em;
      text-transform: uppercase; color: #7c5cff; margin: 0 0 14px; }
    h1 { font-size: clamp(30px, 5vw, 52px); line-height: 1.05; margin: 0 0 16px; font-weight: 700; letter-spacing: -.02em; }
    .lede { font-size: 17px; line-height: 1.6; color: #a1a1aa; max-width: 640px; margin: 0 0 44px; }
    .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    @media (max-width: 720px) { .grid { grid-template-columns: 1fr; } }
    .card { display: block; text-decoration: none; color: inherit; border-radius: 18px; overflow: hidden;
      border: 1px solid rgba(255,255,255,.08); background: rgba(255,255,255,.025);
      transition: transform .2s, border-color .2s; }
    .card:hover { transform: translateY(-4px); border-color: rgba(124,92,255,.5); }
    .card__preview { height: 150px; display: flex; align-items: flex-end; padding: 18px; position: relative; }
    .card__bars { display: flex; gap: 6px; position: absolute; top: 18px; left: 18px; }
    .card__bars span { width: 30px; height: 8px; border-radius: 4px; }
    .card__tag { font-family: "JetBrains Mono", monospace; font-size: 12px; color: rgba(255,255,255,.5);
      position: absolute; top: 16px; right: 18px; }
    .card__body { padding: 20px 22px 24px; }
    .card__body h2 { margin: 0 0 8px; font-size: 21px; }
    .card__body p { margin: 0 0 10px; font-size: 14px; line-height: 1.55; color: #a1a1aa; }
    .card__vibe { font-family: "JetBrains Mono", monospace; font-size: 11.5px; color: #7c5cff; }
    .card__cta { margin-top: 14px; font-size: 13px; font-weight: 600; color: #e7e7ea; }
    .note { margin-top: 44px; font-size: 13px; color: #71717a; line-height: 1.6;
      border-top: 1px solid rgba(255,255,255,.08); padding-top: 20px; }
    .note code { color: #22d3ee; font-family: "JetBrains Mono", monospace; }
    .note a { color: #7c5cff; }
  </style>
</head>
<body>
  <div class="wrap">
    <p class="eyebrow">Redesign · pick one</p>
    <h1>Four directions, one portfolio.</h1>
    <p class="lede">
      Each is a complete identity built on the same real content and the same four interactive demos
      (tokenizer, beat-Phoenix, auto-heal, semantic search). Open each, feel it, then we build the winner for real.
    </p>

    <div class="grid">
      {designs.map((d) => (
        <a class="card" href={`/demos/${d.slug}`}>
          <div class="card__preview" style={`background:${d.swatch[0]}`}>
            <div class="card__bars">
              <span style={`background:${d.swatch[1]}`}></span>
              <span style={`background:${d.swatch[2]}`}></span>
              <span style="background:rgba(255,255,255,.2)"></span>
            </div>
            <span class="card__tag">{d.tag}</span>
            <div style={`font-family:'JetBrains Mono',monospace;font-size:13px;color:${d.swatch[1]}`}>
              ./{d.slug}
            </div>
          </div>
          <div class="card__body">
            <h2>{d.name}</h2>
            <p>{d.blurb}</p>
            <p class="card__vibe">{d.vibe}</p>
            <div class="card__cta">Open demo →</div>
          </div>
        </a>
      ))}
    </div>

    <p class="note">
      These live under <code>/demos/*</code> and are throwaway prototypes, fully isolated from the live site at
      <code>/</code>. The other six directions from the plan (latent-space canvas, Swiss editorial, glass/aurora,
      pixel-art world, scrollytelling, 3D scene) are not built yet. Tell me which of these four to ship and I will
      build the full multi-page site in that language.
    </p>
  </div>
</body>
</html>
