---
import { projects, profile, experience, metrics } from "../../data/demoContent.js";
import Tokenizer from "../../components/demos/Tokenizer.astro";
import BeatPhoenix from "../../components/demos/BeatPhoenix.astro";
import AutoHeal from "../../components/demos/AutoHeal.astro";
import SemanticSearch from "../../components/demos/SemanticSearch.astro";

const cli = {
  profile, metrics,
  projects: projects.map((p) => ({ id: p.id, title: p.title, category: p.category, status: p.status,
    summary: p.summary, stats: p.stats, tech: p.tech, href: p.href })),
  experience,
};
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>02 · Terminal — Design Demo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root { --bg: #0a0e0a; --fg: #c8f7d4; --green: #33ff99; --amber: #ffcc66; --cyan: #5ce1e6;
      --dim: #5a7a64; --line: rgba(51,255,153,.18); }
    * { box-sizing: border-box; }
    body { margin: 0; background: var(--bg); color: var(--fg);
      font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 14px; line-height: 1.6;
      background-image: linear-gradient(rgba(51,255,153,.03) 1px, transparent 1px); background-size: 100% 3px; }

    .demobar { display: flex; align-items: center; gap: 14px; padding: 8px 16px; border-bottom: 1px solid var(--line);
      font-size: 12px; position: sticky; top: 0; background: rgba(10,14,10,.9); backdrop-filter: blur(6px); z-index: 50; }
    .demobar a { color: var(--dim); text-decoration: none; } .demobar a:hover { color: var(--green); }
    .demobar .spacer { flex: 1; } .demobar .active { color: var(--green); }

    .wrap { max-width: 920px; margin: 0 auto; padding: 28px 18px 80px; }
    .term { border: 1px solid var(--line); border-radius: 10px; overflow: hidden; background: rgba(0,0,0,.35);
      box-shadow: 0 0 60px rgba(51,255,153,.06); }
    .term__bar { display: flex; align-items: center; gap: 7px; padding: 9px 13px; border-bottom: 1px solid var(--line);
      background: rgba(51,255,153,.04); }
    .term__bar i { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
    .term__bar .r { background: #ff5f56; } .term__bar .y { background: #ffbd2e; } .term__bar .g { background: #27c93f; }
    .term__bar span { margin-left: 8px; color: var(--dim); font-size: 12px; }
    .term__body { padding: 16px 18px; min-height: 420px; max-height: 62vh; overflow-y: auto; }
    .term__out { white-space: pre-wrap; word-break: break-word; }
    .line { margin: 0; }
    .c-green { color: var(--green); } .c-amber { color: var(--amber); } .c-cyan { color: var(--cyan); } .c-dim { color: var(--dim); }
    .prompt-line { display: flex; gap: 8px; }
    .ps1 { color: var(--green); white-space: nowrap; }
    .term__input { flex: 1; background: transparent; border: 0; outline: 0; color: var(--fg);
      font: inherit; caret-color: var(--green); }
    a { color: var(--cyan); }

    h2.sec { color: var(--green); margin: 56px 0 6px; font-size: 18px; }
    h2.sec::before { content: "## "; color: var(--dim); }
    .sub { color: var(--dim); margin: 0 0 22px; }
    .demo-card { border: 1px solid var(--line); border-radius: 10px; padding: 22px; margin-bottom: 18px; background: rgba(0,0,0,.25);
      --demo-fg: #c8f7d4; --demo-muted: #5a7a64; --demo-accent: #33ff99; --demo-border: rgba(51,255,153,.22);
      --demo-surface: rgba(0,0,0,.35); --demo-surface-2: rgba(51,255,153,.05);
      --demo-mono: "JetBrains Mono", monospace; --demo-sans: "JetBrains Mono", monospace; }
    .demo-card .title { color: var(--green); margin: 0 0 2px; }
    .demo-card .title::before { content: "$ ./"; color: var(--dim); }
    .demo-card .desc { color: var(--dim); margin: 0 0 16px; font-size: 12px; }
    .footer { text-align: center; color: var(--dim); margin-top: 48px; font-size: 12px; }
    @media (max-width: 600px) {
      body { font-size: 12.5px; }
      .wrap { padding: 20px 12px 70px; }
      .term__body { font-size: 11px; overflow-x: auto; }
      .term__out { min-width: 0; }
    }
  </style>
</head>
<body>
  <nav class="demobar">
    <a href="/demos">← all designs</a><span class="spacer"></span>
    <span class="active">02 terminal</span>
    <a href="/demos/graph">01</a><a href="/demos/paper">03</a><a href="/demos/dashboard">04</a>
  </nav>

  <div class="wrap">
    <div class="term" id="term">
      <div class="term__bar"><i class="r"></i><i class="y"></i><i class="g"></i><span>shreyash@portfolio: ~</span></div>
      <div class="term__body" id="body">
        <div class="term__out" id="out"></div>
        <div class="prompt-line"><span class="ps1">shreyash@portfolio:~$</span><input class="term__input" id="input" autocomplete="off" spellcheck="false" autofocus /></div>
      </div>
    </div>

    <h2 class="sec">interactive</h2>
    <p class="sub">// the four demos, same data, plain GUI. all client-side.</p>

    <div class="demo-card"><p class="title">tokenizer</p><p class="desc">Phoenix 32K vs Sweta 64K multilingual BPE</p><Tokenizer /></div>
    <div class="demo-card"><p class="title">semantic_search</p><p class="desc">TF-IDF + cosine over the project corpus</p><SemanticSearch /></div>
    <div class="demo-card"><p class="title">auto_heal</p><p class="desc">IBM SAT three-tier locator recovery</p><AutoHeal /></div>
    <div class="demo-card"><p class="title">beat_phoenix</p><p class="desc">WinoGrande-style commonsense vs the 125M model</p><BeatPhoenix /></div>

    <p class="footer">design demo 02 of 4 · <a href="/demos">back to gallery</a></p>
  </div>

  <script type="application/json" id="cli-data" set:html={JSON.stringify(cli)}></script>
  <script>
    const D = JSON.parse(document.getElementById("cli-data").textContent);
    const out = document.getElementById("out");
    const input = document.getElementById("input");
    const body = document.getElementById("body");
    const esc = (s) => s.replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));
    const print = (html) => { const d = document.createElement("div"); d.className = "line"; d.innerHTML = html; out.appendChild(d); };
    const scroll = () => { body.scrollTop = body.scrollHeight; };

    const banner = [
      '<span class="c-green">  ___ _                              _   </span>',
      '<span class="c-green"> / __| |_  _ _ ___ _  _ __ _ ___| |_ </span>',
      '<span class="c-green"> \\__ \\ \' \\| \'_/ -_) || / _` (_-<| \' \\</span>',
      '<span class="c-green"> |___/_||_|_| \\___|\\_, \\__,_/__/|_||_|</span>',
      '<span class="c-green">                  |__/                </span>',
      '',
      `<span class="c-dim">${D.profile.name} · ${D.profile.role} · ${D.profile.location}</span>`,
      `<span class="c-dim">type</span> <span class="c-amber">help</span> <span class="c-dim">to begin. try</span> <span class="c-amber">projects</span><span class="c-dim">,</span> <span class="c-amber">cat phoenix</span><span class="c-dim">,</span> <span class="c-amber">whoami</span>`,
      '',
    ];

    const HELP = [
      ["help", "this list"],
      ["whoami", "who I am, in one line"],
      ["ls / projects", "list the builds"],
      ["cat <id>", "open a project (e.g. cat phoenix)"],
      ["work", "experience timeline"],
      ["stats", "key metrics"],
      ["tokenize <text>", "rough token count"],
      ["social", "links"],
      ["theme", "toggle phosphor color"],
      ["clear", "clear the screen"],
    ];

    const findProj = (q) => D.projects.find((p) => p.id === q || p.title.toLowerCase().startsWith((q || "").toLowerCase()));

    function run(raw) {
      const [cmd, ...rest] = raw.trim().split(/\s+/);
      const arg = rest.join(" ");
      switch ((cmd || "").toLowerCase()) {
        case "": break;
        case "help":
          print(HELP.map(([c, d]) => `  <span class="c-amber">${c.padEnd(16)}</span><span class="c-dim">${d}</span>`).join("\n")); break;
        case "whoami":
          print(`<span class="c-cyan">${D.profile.tagline}</span> I work where AI systems, backend, and reliability meet.`); break;
        case "ls": case "projects":
          print(D.projects.map((p) => `  <span class="c-green">${p.id.padEnd(12)}</span><span class="c-dim">${p.category} · ${p.status}</span>`).join("\n") +
            `\n<span class="c-dim">→ cat &lt;id&gt; to open</span>`); break;
        case "cat": case "open": {
          const p = findProj(arg);
          if (!p) { print(`<span class="c-amber">cat: ${esc(arg) || "?"}: no such project. try</span> projects`); break; }
          print([
            `<span class="c-green">${p.title}</span> <span class="c-dim">(${p.category} · ${p.status})</span>`,
            ``,
            esc(p.summary),
            ``,
            p.stats.map(([k, v]) => `  <span class="c-cyan">${k.padEnd(12)}</span> ${v}`).join("\n"),
            ``,
            `  <span class="c-dim">tech:</span> ${p.tech.join(", ")}`,
            `  <span class="c-dim">link:</span> <a href="${p.href}" target="_blank" rel="noopener">${p.href}</a>`,
          ].join("\n")); break;
        }
        case "work":
          print(D.experience.map((e) => `  <span class="c-amber">${e.period}</span>  <span class="c-green">${e.role}</span> <span class="c-dim">@ ${e.company}</span>\n    <span class="c-dim">${esc(e.summary)}</span>`).join("\n\n")); break;
        case "stats":
          print(D.metrics.map((m) => `  <span class="c-green">${String(m.value).padEnd(8)}</span><span class="c-dim">${m.label}</span>`).join("\n")); break;
        case "tokenize": {
          if (!arg) { print('<span class="c-amber">usage: tokenize some text here</span>'); break; }
          const n = (arg.match(/\S+/g) || []).reduce((a, w) => a + Math.max(1, Math.ceil(w.length / 4)), 0);
          print(`<span class="c-dim">~</span><span class="c-green">${n}</span><span class="c-dim"> tokens (rough). full BPE demo lives below ↓</span>`); break;
        }
        case "social":
          print(`  <a href="${D.profile.github}" target="_blank">github</a>   <a href="${D.profile.huggingFace}" target="_blank">huggingface</a>   <a href="${D.profile.linkedin}" target="_blank">linkedin</a>`); break;
        case "theme": {
          const root = document.documentElement;
          const cur = getComputedStyle(root).getPropertyValue("--green").trim();
          const next = cur === "#ffcc66" ? "#33ff99" : "#ffcc66";
          root.style.setProperty("--green", next); root.style.setProperty("--fg", next === "#ffcc66" ? "#ffe9bf" : "#c8f7d4");
          print(`<span class="c-dim">phosphor set to</span> <span class="c-green">${next === "#ffcc66" ? "amber" : "green"}</span>`); break;
        }
        case "clear": out.innerHTML = ""; return;
        default:
          print(`<span class="c-amber">${esc(cmd)}: command not found.</span> <span class="c-dim">type help</span>`);
      }
    }

    banner.forEach((l) => print(l || "&nbsp;"));
    const history = []; let hi = 0;
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const v = input.value;
        print(`<span class="prompt-line"><span class="ps1">shreyash@portfolio:~$</span> ${esc(v)}</span>`);
        if (v.trim()) { history.push(v); hi = history.length; }
        run(v); input.value = ""; scroll();
      } else if (e.key === "ArrowUp") { if (hi > 0) input.value = history[--hi]; e.preventDefault(); }
      else if (e.key === "ArrowDown") { hi = Math.min(history.length, hi + 1); input.value = history[hi] || ""; e.preventDefault(); }
    });
    document.getElementById("term").addEventListener("click", () => input.focus());
    input.focus();
  </script>
</body>
</html>
