---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Reveal from '../../components/Reveal.astro';
import ActionLink from '../../components/ActionLink.astro';
import { flagshipProjects } from '../../data/siteContent';

export function getStaticPaths() {
  return flagshipProjects.map((proj) => ({
    params: { slug: proj.slug },
    props: { project: proj },
  }));
}

const { project: proj } = Astro.props;

const statusColors: Record<string, string> = {
  Released: 'var(--bg-emerald)',
  Live: 'var(--bg-emerald)',
  Parked: '#6B7280',
  'In Progress': 'var(--bg-accent)',
};
const statusColor = statusColors[proj.status] ?? 'var(--bg-accent)';

const title = `${proj.title} · Shreyash Pandey`;
const description = proj.tagline ?? proj.summary;
---

<BaseLayout title={title} description={description}>
  <div class="reading-progress" aria-hidden="true"></div>

  {/* ── HERO ── */}
  <section class="page__section">
    <div class="bento reveal-stagger">
      <Reveal class="card span-3">
        <a
          href="/projects"
          class="back-link t-eyebrow"
          style="display:inline-flex;align-items:center;gap:6px;color:var(--text-secondary);text-decoration:none;margin-bottom:20px;"
        >
          ← All projects
        </a>
        <p class="t-eyebrow card__eyebrow">{proj.year} · {proj.category}</p>
        <h1 class="t-display card__title">{proj.title}</h1>
        <p class="t-body--lg" style="max-width:640px;">{proj.tagline}</p>
      </Reveal>

      <Reveal
        class="card card--dark span-1"
        style="display:flex;flex-direction:column;justify-content:center;align-items:center;gap:16px;min-height:160px;"
      >
        <span
          style={`background:${statusColor};color:#fff;padding:6px 16px;border-radius:20px;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;`}
        >
          {proj.status}
        </span>
        <span
          class="t-small"
          style="color:rgba(255,255,255,0.4);text-align:center;font-family:var(--font-mono);"
        >
          {proj.year}
        </span>
      </Reveal>
    </div>
  </section>

  {/* ── WHY I BUILT THIS ── */}
  <section class="page__section">
    <Reveal class="card card--dark" style="padding:40px 44px;">
      <p class="t-eyebrow card__eyebrow" style="color:rgba(255,255,255,0.45);">
        Why I built this
      </p>
      <p class="t-body--lg" style="color:var(--text-on-dark);max-width:760px;line-height:1.75;">
        {proj.why}
      </p>
    </Reveal>
  </section>

  {/* ── STATS + STATUS NOTE ── */}
  {proj.stats && (
    <section class="page__section">
      <div class="bento reveal-stagger">
        {proj.stats.map((stat) => (
          <Reveal class="card" style="text-align:center;padding:32px 20px;">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label" style="display:block;margin-top:6px;">{stat.label}</span>
          </Reveal>
        ))}
        {proj.statusNote && (
          <Reveal class="card card--accent">
            <p class="t-eyebrow card__eyebrow" style="color:rgba(255,255,255,0.55);">
              Current status
            </p>
            <p class="t-body" style="color:#fff;">{proj.statusNote}</p>
          </Reveal>
        )}
      </div>
    </section>
  )}

  {/* ── ARCHITECTURE ── */}
  {proj.architecture && (
    <section class="page__section">
      <Reveal style="margin-bottom:16px;">
        <p class="t-eyebrow">Architecture</p>
      </Reveal>
      <div class="bento reveal-stagger">
        {proj.architecture.map((component, i) => {
          const span = component.span ?? 2;
          const isDark = component.dark ?? (i === 0 && !component.diagram);
          const cardClass = `card span-${span}${isDark ? ' card--dark' : ''}${component.diagram ? ' card--diagram' : ''}`;
          const eyebrowStyle = isDark ? 'color:rgba(255,255,255,0.45)' : '';
          const bodyStyle = isDark ? 'color:rgba(255,255,255,0.85)' : '';
          return (
            <Reveal class={cardClass}>
              <p class="t-eyebrow card__eyebrow" style={eyebrowStyle}>
                {component.name}
              </p>
              {component.description && (
                <p class="t-body" style={bodyStyle}>{component.description}</p>
              )}
              {component.diagram && (
                <div class="mermaid-wrap">
                  <pre class="mermaid">{component.diagram}</pre>
                </div>
              )}
            </Reveal>
          );
        })}
      </div>
    </section>
  )}

  {/* ── TECH STACK + HIGHLIGHTS ── */}
  <section class="page__section">
    <div class="bento reveal-stagger">

      {/* Tech stack */}
      <Reveal class="card span-2">
        <p class="t-eyebrow card__eyebrow">Tech stack</p>
        <h3 class="t-subheading card__title" style="font-size:1rem;margin-bottom:20px;">
          Technologies used
        </h3>
        {Object.entries(proj.techStack).map(([group, items]: [string, string[]]) => (
          <div style="margin-bottom:18px;">
            <p
              class="t-small"
              style="color:var(--text-tertiary);margin-bottom:8px;text-transform:capitalize;font-weight:600;"
            >
              {group}
            </p>
            <div class="chip-grid">
              {items.map((item: string) => (
                <span class="chip chip--outline">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </Reveal>

      {/* Highlights */}
      <Reveal class="card card--dark span-2">
        <p class="t-eyebrow card__eyebrow" style="color:rgba(255,255,255,0.45);">
          Key highlights
        </p>
        <h3
          class="t-subheading card__title"
          style="color:var(--text-on-dark);font-size:1rem;margin-bottom:20px;"
        >
          Proof points
        </h3>
        <ol style="list-style:none;padding:0;margin:0;">
          {proj.highlights.map((h: string, i: number) => (
            <li style="display:flex;gap:14px;margin-bottom:16px;align-items:flex-start;">
              <span
                style="color:rgba(255,255,255,0.25);font-family:var(--font-mono);font-size:0.7rem;min-width:22px;padding-top:3px;font-weight:600;"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <p class="t-small" style="color:rgba(255,255,255,0.8);margin:0;line-height:1.6;">
                {h}
              </p>
            </li>
          ))}
        </ol>
      </Reveal>

    </div>
  </section>

  {/* ── BENCHMARKS ── */}
  {proj.benchmarks && (
    <section class="page__section">
      <Reveal style="margin-bottom:16px;">
        <p class="t-eyebrow">Benchmark results</p>
      </Reveal>
      <div class="bento reveal-stagger">
        {proj.benchmarks.map((b: { name: string; value: string; note: string }) => (
          <Reveal class="card" style="text-align:center;padding:28px 20px;">
            <span class="stat-value" style="font-size:1.75rem;">{b.value}</span>
            <p class="t-small card__title" style="margin-top:6px;font-weight:600;">{b.name}</p>
            <p class="t-small" style="color:var(--text-tertiary);margin-top:3px;">{b.note}</p>
          </Reveal>
        ))}
      </div>
    </section>
  )}

  {/* ── FOOTER: SKILLS + LINKS ── */}
  <section class="page__section">
    <div class="bento reveal-stagger">

      <Reveal class="card span-2">
        <p class="t-eyebrow card__eyebrow">Focus areas</p>
        <div class="chip-grid" style="margin-top:10px;">
          {proj.skills.map((s: string) => (
            <span class="chip chip--outline">{s}</span>
          ))}
        </div>
      </Reveal>

      <Reveal
        class="card card--emerald span-2"
        style="display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;gap:16px;padding:36px 28px;"
      >
        <p class="t-eyebrow card__eyebrow" style="color:rgba(255,255,255,0.55);">
          Explore the work
        </p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;">
          {proj.href && (
            <ActionLink
              href={proj.href}
              external={true}
              label={proj.ctaLabel ?? 'View project'}
              variant="ghost"
              small={true}
              class="btn--on-dark"
            />
          )}
          <ActionLink
            href="/projects"
            label="← All projects"
            variant="ghost"
            small={true}
            class="btn--on-dark"
          />
        </div>
      </Reveal>

    </div>
  </section>

  {proj.architecture?.some((c: any) => c.diagram) && (
    <script type="module" is:inline>
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
      mermaid.initialize({
        startOnLoad: false,
        theme: 'base',
        themeVariables: {
          fontFamily: 'Inter, system-ui, sans-serif',
          fontSize: '14px',
          primaryColor: '#ffffff',
          primaryTextColor: '#1a1a1a',
          primaryBorderColor: '#1a1a1a',
          lineColor: '#1a1a1a',
          tertiaryColor: '#f5f5f5',
        },
        flowchart: { htmlLabels: true, curve: 'basis', padding: 16 },
        securityLevel: 'loose',
      });
      await mermaid.run({ querySelector: '.mermaid' });
    </script>
  )}

</BaseLayout>
