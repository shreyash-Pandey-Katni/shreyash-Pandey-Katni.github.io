---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeView from '../../components/views/HomeView.astro';
import { getContent } from '../../i18n/index.js';

const locale = 'zh';
const { title, description } = getContent(locale).pageMeta['/'];
